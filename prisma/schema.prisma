// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ==========================================
// NextAuth.js Required Models
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// Application Models
// ==========================================

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?

  // NextAuth relations
  accounts       Account[]
  sessions       Session[]

  // Application relations
  ownedTools     Tool[]    @relation("UserTools")
  rentals        Reservation[] @relation("RenterReservations")
  ownerReservations Reservation[] @relation("OwnerReservations")

  // Messaging relations
  conversations  Conversation[] @relation("UserConversations")
  messages       Message[]      @relation("UserMessages")
}

model Conversation {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Participants
  participants User[] @relation("UserConversations")

  // Messages in this conversation
  messages     Message[]

  // Optional: Link to a tool or booking to provide context
  toolId       String?
  tool         Tool?     @relation(fields: [toolId], references: [id])
}

model Message {
  id             String       @id @default(cuid())
  content        String
  createdAt      DateTime     @default(now())
  
  // Sender
  senderId       String
  sender         User         @relation("UserMessages", fields: [senderId], references: [id])

  // Conversation
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  // Type for conditional rendering (e.g., "TEXT", "BOOKING_REQUEST")
  type           String       @default("TEXT")
  
  // Optional: link to a reservation for action buttons
  reservationId      String?
  reservation        Reservation?     @relation(fields: [reservationId], references: [id])
}

model Tool {
  id          String    @id @default(cuid())
  title       String
  description String
  pricePerDay Float
  category    String
  location    String
  imageUrl    String?
  latitude    Float?
  longitude   Float?

  // Relation avec User (Propriétaire)
  ownerId     String
  owner       User      @relation("UserTools", fields: [ownerId], references: [id])

  reservations    Reservation[]
  conversations Conversation[]
}

model Reservation {
  id           String   @id @default(cuid())
  outil_id     String
  locataire_id String
  proprietaire_id String
  date_debut   DateTime
  date_fin     DateTime
  statut       String   @default("en_attente") // en_attente, valide, annule, contre_offre
  prix_total   Float
  prix_propose Float?

  // Relations
  outil        Tool     @relation(fields: [outil_id], references: [id])
  locataire    User     @relation("RenterReservations", fields: [locataire_id], references: [id])
  proprietaire User     @relation("OwnerReservations", fields: [proprietaire_id], references: [id])
  
  messages     Message[]
}
