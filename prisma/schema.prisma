// prisma/schema.prisma

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma/client"
}

datasource db {
  provider = "sqlite"
}

// ==========================================
// NextAuth.js Required Models
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// Application Models
// ==========================================

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?

  // NextAuth relations
  accounts       Account[]
  sessions       Session[]

  // Application relations
  ownedTools     Tool[]    @relation("UserTools")
  rentals        Booking[] @relation("RenterBookings")
}

model Tool {
  id          String    @id @default(cuid())
  title       String
  description String
  pricePerDay Float
  category    String
  location    String
  imageUrl    String?

  // Relation avec User (Propriétaire)
  ownerId     String
  owner       User      @relation("UserTools", fields: [ownerId], references: [id])

  bookings    Booking[]
}

model Booking {
  id         String   @id @default(cuid())
  startDate  DateTime
  endDate    DateTime
  status     String   @default("PENDING")
  totalPrice Float

  // Relation avec Tool (Outil loué)
  toolId     String
  tool       Tool     @relation(fields: [toolId], references: [id])

  // Relation avec User (Locataire)
  renterId   String
  renter     User     @relation("RenterBookings", fields: [renterId], references: [id])
}
